<?php

/**
 * @file
 * Install, update and uninstall functions for the TS Lodge module.
 */

/**
 * Implements hook_install().
 */
function ts_lodge_install(): void {
  // Ensure REST and serialization modules are enabled.
  \Drupal::service('module_installer')->install(['rest', 'serialization'], TRUE);

  // Install REST resource config and role config.
  \Drupal::service('config.installer')->installDefaultConfig('module', 'ts_lodge');

  // Create the entity type database tables.
  $manager = \Drupal::entityDefinitionUpdateManager();
  $entity_type_manager = \Drupal::entityTypeManager();
  foreach (['ts_lodge_usager', 'ts_lodge_booking', 'ts_lodge_programme'] as $type) {
    $definition = $entity_type_manager->getDefinition($type, FALSE);
    if ($definition) {
      $manager->installEntityType($definition);
    }
  }
}

/**
 * Implements hook_uninstall().
 */
function ts_lodge_uninstall(): void {
  // Clean up any orphaned config.
  \Drupal::configFactory()->getEditable('rest.resource.ts_lodge_usager_resource')->delete();
  \Drupal::configFactory()->getEditable('rest.resource.ts_lodge_booking_resource')->delete();
  \Drupal::configFactory()->getEditable('rest.resource.ts_lodge_programme_resource')->delete();
}

/**
 * Implements hook_schema().
 *
 * Drupal's entity API creates the base tables automatically, but we define
 * the schema here so that hook_requirements and inspection tools can see it.
 */
